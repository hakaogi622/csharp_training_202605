@{
    ViewData["Title"] = "Home Page";
}

<div class="container">
    <h1>社員・部門管理システム</h1>
</div>

<div class="contents">
    <section class="system-card">
        <h2 style="margin-bottom:20px;">
            <p>
                社員管理
            </p>
        </h2>

        <div class="button-group" style="margin-bottom:50px;">
            <a class="btn btn-lg btn-primary" asp-controller="EmployeeList" asp-action="ShowEmp">
                社員一覧
            </a>

            <a class="btn btn-lg btn-primary" asp-controller="EmployeeRegister" asp-action="Enter">
                社員登録
            </a>
        </div>
    </section>

    <section class="contents">
        <h2 style="margin-bottom:20px;">
            <p>
                部門管理
            </p>
        </h2>

        <div class="button-group" style="margin-bottom:50px;">
            <a class="btn btn-lg btn-primary" asp-controller="DepartmentList" asp-action="ShowDept">
                部門一覧
            </a>

            <a class="btn btn-lg btn-primary" asp-controller="DepartmentRegister" asp-action="Enter">
                部門登録
            </a>
        </div>
    </section>

</div>