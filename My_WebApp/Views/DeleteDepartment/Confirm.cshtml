@*Confirm.cshtml(社員削除の確認画面)*@

@using WebApp_Src.Presentations.ViewModels
@model DeleteDepartmentViewModel;
@{
    ViewData["Title"] = "部門削除(確認)";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-sm-8">
            <a class="message">
                次の社員を削除しますか？
            </a>
            <div asp-validation-summary="All" class="text-danger"></div>
            <table class="table table-hover">
                <tbody>
                    <tr>
                        @*DeleteEmployeeViewModelのNameプロパティの値を表示する*@
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.DeptId)</td>
                        <td>@Html.DisplayFor(m => m.DeptId)</td>
                    </tr>
                    <tr>
                        @*メールアドレス*@
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.DeptName)</td>
                        <td>@Html.DisplayFor(m => m.DeptName)</td>

                    </tr>
                </tbody>
            </table>

            <form>
                @*POSTリクエスト(Register/Back)に値を渡すためにhidden属性を使う*@
                @*これがないと、次の画面で値が消えてしまう*@
                <input type="hidden" asp-for="DeptId" />
                <input type="hidden" asp-for="DeptName" />
                @*formaction/formmethod ボタンごとに送信先を変える*@
                @*同じフォーム内で[登録]と[戻る]を分岐できる*@
                <div class="text-center mt-4">
                    <button type="submit" formaction="@Url.Action("Delete", "DeleteDepartment")" formmethod="post"
                            class="btn btn-primary">削除</button>
                    <a class="btn btn-primary" asp-controller="DepartmentList" asp-action="ShowDept">
                        戻る
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>